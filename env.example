# .env.example — copy to .env and fill in real values
# Generate VAULT_KEY_HEX with:
#   python -c "import secrets; print(secrets.token_hex(32))"

BOT_TOKEN=7xxxxxxxxx:AAF_your_bot_token_here
VAULT_KEY_HEX=replace_with_64_hex_chars
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/alphabot
REDIS_URL=redis://localhost:6379/0
ADMIN_ID=123456789
CRYPTOBOT_TOKEN=your_cryptobot_token
SUBSCRIPTION_PRICE_USD=30.00
REFERRAL_COMMISSION_PCT=10
